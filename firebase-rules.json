{
  "_comentario": "Regras de seguranca do Firebase Realtime Database para o Enlace. Cole em Console Firebase > Realtime Database > Regras. Veja SEGURANCA.md para o contexto. A protecao DEFINITIVA exige migrar para Firebase Authentication (secao no fim deste arquivo).",

  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".indexOn": ["email"],
      ".read": true,
      "$uid": {
        ".write": "!data.exists() || newData.child('id').val() === $uid",
        ".validate": "newData.hasChildren(['id','email','role','createdAt'])",
        "role": { ".validate": "newData.val() === 'client' || newData.val() === 'professional' || newData.val() === 'admin'" },
        "password": { ".validate": "false" },
        "email": { ".validate": "newData.isString() && newData.val().length <= 254" },
        "name":  { ".validate": "newData.isString() && newData.val().length <= 120" },
        "$other": { ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren()" }
      }
    },

    "professionals": {
      ".read": true,
      "$pid": {
        ".write": "newData.child('id').val() === $pid",
        "password":     { ".validate": "false" },
        "passwordHash": { ".validate": "false" },
        "passwordSalt": { ".validate": "false" }
      }
    },

    "requests": {
      ".read": true,
      "$rid": {
        ".write": true,
        ".validate": "newData.hasChildren(['id','clientId','professionalId','status'])"
      }
    },

    "ads": {
      ".read": true,
      "$id": { ".write": true }
    },

    "profAds": {
      ".read": true,
      "$id": { ".write": true }
    }
  },

  "_REGRAS_IDEAIS_COM_FIREBASE_AUTH": {
    "_explicacao": "Apos migrar login/cadastro para Firebase Authentication (firebase.auth().createUserWithEmailAndPassword / signInWithEmailAndPassword), o Firebase ja guarda e protege as senhas com hash forte no servidor, e voce NUNCA precisa salvar senha no banco. Use entao estas regras, que so liberam dados a usuarios autenticados e impedem leitura em massa:",
    "rules": {
      "users": {
        "$uid": {
          ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
          ".write": "auth != null && auth.uid === $uid"
        }
      },
      "professionals": {
        ".read": "auth != null",
        "$pid": { ".write": "auth != null && auth.uid === $pid" }
      },
      "requests": {
        ".read": "auth != null",
        "$rid": { ".write": "auth != null" }
      },
      "ads":     { ".read": "auth != null", "$id": { ".write": "root.child('users').child(auth.uid).child('role').val() === 'admin'" } },
      "profAds": { ".read": "auth != null", "$id": { ".write": "auth != null" } }
    }
  }
}
