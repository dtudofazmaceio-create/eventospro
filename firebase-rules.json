{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".indexOn": [
        "email"
      ],
      ".read": true,
      "$uid": {
        ".write": "!data.exists() || newData.child('id').val() === $uid || (auth != null && data.child('email').val() === auth.token.email)",
        ".validate": "newData.hasChildren(['id','email','role','createdAt'])",
        "role": {
          ".validate": "newData.val() === 'client' || newData.val() === 'professional' || newData.val() === 'admin'"
        },
        "password": {
          ".validate": "false"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 254"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren()"
        }
      }
    },
    "professionals": {
      ".read": true,
      "$pid": {
        ".write": "newData.child('id').val() === $pid || (auth != null && !newData.exists())",
        "password": {
          ".validate": "false"
        },
        "passwordHash": {
          ".validate": "false"
        },
        "passwordSalt": {
          ".validate": "false"
        }
      }
    },
    "requests": {
      ".read": true,
      "$rid": {
        ".write": true,
        ".validate": "newData.hasChildren(['id','clientId','professionalId','status'])"
      }
    },
    "ads": {
      ".read": true,
      "$id": {
        ".write": true
      }
    },
    "profAds": {
      ".read": true,
      "$id": {
        ".write": true
      }
    }
  }
}
