{
  "rules": {
    ".read": false,
    ".write": false,
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".indexOn": [
        "email"
      ],
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['id','email','role','createdAt'])",
        "role": {
          ".validate": "newData.val() === 'client' || newData.val() === 'professional' || newData.val() === 'admin'"
        },
        "password": {
          ".validate": "false"
        },
        "passwordHash": {
          ".validate": "false"
        },
        "passwordSalt": {
          ".validate": "false"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 254"
        },
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 120"
        },
        "$other": {
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean() || newData.hasChildren()"
        }
      }
    },
    "professionals": {
      ".read": "auth != null",
      "$pid": {
        ".write": "auth != null && (auth.uid === $pid || auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin')",
        "password": {
          ".validate": "false"
        },
        "passwordHash": {
          ".validate": "false"
        },
        "passwordSalt": {
          ".validate": "false"
        }
      }
    },
    "requests": {
      ".read": "auth != null",
      "$rid": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['id','clientId','professionalId','status'])"
      }
    },
    "ads": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
      }
    },
    "profAds": {
      ".read": "auth != null",
      "$id": {
        ".write": "auth != null"
      }
    }
  }
}